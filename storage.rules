rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function orderDoc(orderId) {
      return firestore.get(/databases/(default)/documents/orders/$(orderId));
    }

    function userRole() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }

    function canReadOrderAttachment(orderId) {
      return request.auth != null
        && orderDoc(orderId).data != null
        && (
          orderDoc(orderId).data.customerId == request.auth.uid
          || userRole() in ['manager', 'admin']
          || orderDoc(orderId).data.assignedDeveloperId == request.auth.uid
        );
    }

    function validAttachmentUpload(orderId) {
      return request.auth != null
        && orderDoc(orderId).data != null
        && orderDoc(orderId).data.customerId == request.auth.uid
        && orderDoc(orderId).data.status == 'new'
        && (
          (request.resource.contentType.matches('image/.*') && request.resource.size < 10 * 1024 * 1024)
          || (request.resource.contentType.matches('video/.*') && request.resource.size < 50 * 1024 * 1024)
        );
    }

    match /order-attachments/{orderId}/{fileName} {
      allow read: if canReadOrderAttachment(orderId);
      allow write: if validAttachmentUpload(orderId);
    }
  }
}
